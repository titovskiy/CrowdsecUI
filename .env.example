# URL of CrowdSec Local API (LAPI)
CROWDSEC_API_URL=http://crowdsec:8080

# Read-only mode (bouncer): can view decisions
# Generate with: sudo cscli bouncers add crowdsec-webui
CROWDSEC_API_KEY=put-your-bouncer-key-here

# Write mode (machine): required for create/delete decisions in UI
# Create with: sudo cscli machines add crowdsec-webui
CROWDSEC_MACHINE_LOGIN=
CROWDSEC_MACHINE_PASSWORD=

HTTP_TIMEOUT=10

# Web UI host port
WEB_PORT=8088
